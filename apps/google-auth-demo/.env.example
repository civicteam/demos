# Auth.js (NextAuth)
NEXTAUTH_URL=http://localhost:3025
NEXTAUTH_SECRET=your-32-character-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Civic Auth Token Exchange
# Note: manual exchange is used because Google issues ID tokens, which require
# subject_token_type=id_token (not yet supported by @civic/mcp-client's built-in tokenExchange)
CIVIC_AUTH_URL=https://auth.civic.com/oauth
CIVIC_CLIENT_ID=your-civic-client-id
CIVIC_CLIENT_SECRET=your-civic-client-secret

# Civic Profile (optional — lock the client to a specific profile UUID)
# CIVIC_PROFILE=

# MCP Hub URL (optional — defaults to https://app.civic.com/hub/mcp)
# MCP_SERVER_URL=

# LLM
ANTHROPIC_API_KEY=
