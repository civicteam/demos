# Auth.js (NextAuth)
NEXTAUTH_URL=http://localhost:3025
NEXTAUTH_SECRET=your-32-character-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Civic Auth (token exchange is handled by @civic/mcp-client)
CIVIC_CLIENT_ID=your-civic-client-id
CIVIC_CLIENT_SECRET=your-civic-client-secret

# Civic Profile (optional — lock the client to a specific profile UUID)
# CIVIC_PROFILE=

# MCP Hub URL (optional — defaults to https://app.civic.com/hub/mcp)
# MCP_SERVER_URL=

# LLM
ANTHROPIC_API_KEY=
