# =========================================
# Auth.js Configuration
# =========================================
# URL where the app runs (update for production)
NEXTAUTH_URL=http://localhost:3022

# Secret for encrypting cookies (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-32-character-secret-here

# =========================================
# RSA Key Pair for JWT Signing
# =========================================
# Generate keys with: pnpm tsx scripts/generate-keys.ts
# These keys sign the JWTs that are exchanged for Civic tokens
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# =========================================
# Civic Auth Token Exchange
# =========================================
# Production Civic Auth endpoint
CIVIC_AUTH_URL=https://auth.civic.com/oauth

# Civic Auth application credentials from auth.civic.com
CIVIC_AUTH_CLIENT_ID=your-civic-client-id
CIVIC_AUTH_CLIENT_SECRET=your-civic-client-secret

# =========================================
# MCP Hub Configuration
# =========================================
# Production MCP Hub endpoint
MCP_SERVER_URL=https://nexus.civic.com/hub/mcp

# Local development (uncomment to use)
#MCP_SERVER_URL=http://localhost:3001/mcp

# =========================================
# Logging
# =========================================
DEBUG=federated-auth-demo:*
LOG_LEVEL=debug
LOG_PRETTY=true

# =========================================
# Deployment (optional)
# =========================================
NEXT_PUBLIC_BASE_PATH=
WEB_APP_ORIGIN=https://nexus.civic.com
