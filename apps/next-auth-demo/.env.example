
# =========================================
# LLM Provider
# =========================================
ANTHROPIC_API_KEY=
# =========================================
# Auth.js Configuration
# =========================================
# URL where the app runs (update for production)
NEXTAUTH_URL=http://localhost:3020

# Secret for encrypting cookies (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-32-character-secret-here

# JWT Issuer and Audience for token exchange with Civic Auth (update ISSUER to your deployed URL in production)
ISSUER=
AUDIENCE=

# =========================================
# RSA Key Pair for JWT Signing
# =========================================
# Generate keys with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl pkey -in private.pem -pubout -out public.pem
# Then paste each as a single line with \n for newlines
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# =========================================
# Civic Auth Token Exchange
# =========================================
# Civic Auth application credentials from auth.civic.com
CIVIC_CLIENT_ID=your-civic-client-id
CIVIC_CLIENT_SECRET=your-civic-client-secret

# Civic profile ID (UUID from your Civic organization)
CIVIC_PROFILE_ID=your-civic-profile-id

